---
interface Props {
  href: string;
  variant?: "primary" | "secondary";
  class?: string;
  external?: boolean;
}

const { href, variant = "primary", class: className = "", external = true } = Astro.props;
const target = external ? "_blank" : undefined;
const rel = external ? "noopener noreferrer" : undefined;
---

{variant === "primary" ? (
  <a
    href={href}
    target={target}
    rel={rel}
    class:list={[
      "inline-flex items-center gap-2 px-6 py-3 rounded-xl font-heading font-semibold text-sm",
      "bg-gradient-to-r from-violet-primary to-deep-purple",
      "text-white shadow-lg shadow-violet-primary/20",
      "hover:shadow-xl hover:shadow-violet-primary/30 hover:-translate-y-0.5",
      "transition-all duration-300 ease-out",
      className,
    ]}
  >
    <slot />
  </a>
) : (
  <a
    href={href}
    target={target}
    rel={rel}
    class:list={[
      "inline-flex items-center gap-2 px-6 py-3 rounded-xl font-heading font-semibold text-sm",
      "glass-card text-lavender",
      "hover:bg-white/[0.06] hover:border-violet-primary/50 hover:-translate-y-0.5",
      "transition-all duration-300 ease-out",
      className,
    ]}
  >
    <slot />
  </a>
)}
