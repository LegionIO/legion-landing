---
import SectionHeading from "./ui/SectionHeading.astro";
import GlowCard from "./ui/GlowCard.astro";

const components = [
  {
    name: "Router",
    role: "legion-llm",
    description: "Five tiers — local(0), direct(1), fleet(2), cloud(3), frontier(4). Each request starts at the most cost-effective capable tier and escalates on failure or capability mismatch. Circuit breakers per provider instance; a provider dying mid-stream fails over and the stream continues.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12h5"/><path d="M17 12h5"/><path d="m7 7 5 5-5 5"/><path d="m12 7 5 5-5 5"/></svg>`,
  },
  {
    name: "Curator",
    role: "legion-llm",
    description: "Runs after each turn, off the request path. Six deterministic strategies shrink accumulated history — stale reasoning stripped, tool results distilled, resolved exchanges folded, superseded reads evicted, near-duplicates removed, overflow archived to the knowledge store.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22v-5"/><path d="M9 8V2"/><path d="M15 8V2"/><path d="M18 8v5a6 6 0 0 1-6 6 6 6 0 0 1-6-6V8Z"/></svg>`,
  },
  {
    name: "Job Engine",
    role: "legionio",
    description: "The original core: task chains with conditions and transformations, eight actor types, distributed cron scheduling, and a disk spool that rides out broker outages. RabbitMQ-backed in full mode, in-process in lite mode.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="8" x="2" y="2" rx="2" ry="2"/><rect width="20" height="8" x="2" y="14" rx="2" ry="2"/><line x1="6" x2="6.01" y1="6" y2="6"/><line x1="6" x2="6.01" y1="18" y2="18"/></svg>`,
  },
  {
    name: "GAIA + Apollo",
    role: "legion-gaia / legion-apollo",
    description: "The knowledge side: Apollo stores what your deployment learns (pgvector-backed semantic retrieval with confidence decay), GAIA schedules the background work that maintains it and feeds RAG context back into the LLM layer.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5v14a9 3 0 0 0 18 0V5"/><path d="M3 12a9 3 0 0 0 18 0"/></svg>`,
  },
];

const tiers = ["local", "direct", "fleet", "cloud", "frontier"];

const curatorStrategies = [
  "strip_thinking", "distill_tool_result", "fold_resolved_exchanges",
  "evict_superseded", "dedup_similar", "drop_and_archive",
];
---

<section id="architecture" class="py-14 md:py-20">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <SectionHeading
      label="Architecture"
      title="Architecture"
      subtitle="A proxy in front, a job engine underneath, a knowledge layer beside it. Every piece is a separate gem; install only what you use."
    />

    <!-- Core Components -->
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 mb-16" data-reveal-stagger>
      {components.map((comp) => (
        <GlowCard>
          <div class="text-violet-primary mb-4" set:html={comp.icon} />
          <h3 class="text-lg font-heading font-bold text-surface-100 mb-1">{comp.name}</h3>
          <span class="text-xs font-mono text-violet-primary/80 uppercase tracking-wider">{comp.role}</span>
          <p class="text-sm text-surface-400 mt-3 leading-relaxed">{comp.description}</p>
        </GlowCard>
      ))}
    </div>

    <!-- Routing tiers -->
    <div class="mb-12" data-reveal>
      <h3 class="text-center text-lg font-heading font-semibold text-surface-200 mb-2">
        Routing Tiers
      </h3>
      <p class="text-center text-sm text-surface-500 mb-6">
        Each request starts at the most cost-effective tier able to serve it, escalating
        only when needed. Defined in
        <a href="https://github.com/LegionIO/legion-llm/blob/main/lib/legion/llm/router.rb" class="text-violet-primary hover:text-lavender underline underline-offset-2">router.rb</a>.
      </p>
      <div class="flex flex-wrap justify-center gap-2 max-w-3xl mx-auto">
        {tiers.map((tier, i) => (
          <div class="flex items-center gap-2">
            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm text-surface-200 font-medium glass-card glow-border hover:border-violet-primary/25 hover:bg-white/[0.06] transition-all duration-300" style="backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);">
              <span class="text-xs text-violet-primary/60 font-mono">{i}</span>
              {tier}
            </span>
            {i < tiers.length - 1 && (
              <svg class="w-3 h-3 text-surface-600 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="m9 18 6-6-6-6" />
              </svg>
            )}
          </div>
        ))}
      </div>
    </div>

    <!-- Curator strategies -->
    <div data-reveal>
      <h3 class="text-center text-lg font-heading font-semibold text-surface-200 mb-2">
        Curator Strategies
      </h3>
      <p class="text-center text-sm text-surface-500 mb-6">
        Six deterministic passes, each a named method in
        <a href="https://github.com/LegionIO/legion-llm/blob/main/lib/legion/llm/context/curator.rb" class="text-violet-primary hover:text-lavender underline underline-offset-2">curator.rb</a>.
        Measured results, including where they save nothing, in the
        <a href="https://github.com/LegionIO/legion-llm/blob/main/docs/curation-production-metrics.md" class="text-violet-primary hover:text-lavender underline underline-offset-2">production metrics</a>.
      </p>
      <div class="flex flex-wrap justify-center gap-2 max-w-2xl mx-auto">
        {curatorStrategies.map((strategy) => (
          <span class="inline-flex items-center px-3 py-1.5 rounded-lg text-sm text-surface-300 font-mono glass-card glow-border hover:border-violet-primary/25 hover:bg-white/[0.06] transition-all duration-300" style="backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);">
          {strategy}
          </span>
        ))}
      </div>
    </div>
  </div>
</section>
