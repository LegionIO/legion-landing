---
import SectionHeading from "./ui/SectionHeading.astro";
import GlowCard from "./ui/GlowCard.astro";

const audiences = [
  {
    title: "AI Researchers",
    description: "Explore cognitive architectures beyond prompt engineering. Experiment with biologically-inspired processing, memory consolidation, and emergent behavior.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.5 2A2.5 2.5 0 0 1 12 4.5v15a2.5 2.5 0 0 1-4.96.44 2.5 2.5 0 0 1-2.96-3.08 3 3 0 0 1-.34-5.58 2.5 2.5 0 0 1 1.32-4.24 2.5 2.5 0 0 1 1.98-3A2.5 2.5 0 0 1 9.5 2Z"/><path d="M14.5 2A2.5 2.5 0 0 0 12 4.5v15a2.5 2.5 0 0 0 4.96.44 2.5 2.5 0 0 0 2.96-3.08 3 3 0 0 0 .34-5.58 2.5 2.5 0 0 0-1.32-4.24 2.5 2.5 0 0 0-1.98-3A2.5 2.5 0 0 0 14.5 2Z"/></svg>`,
  },
  {
    title: "Platform Engineers",
    description: "Orchestrate infrastructure with 80+ service integrations. Chain tasks, manage schedules, and coordinate distributed workers across your stack.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="8" x="2" y="2" rx="2" ry="2"/><rect width="20" height="8" x="2" y="14" rx="2" ry="2"/><line x1="6" x2="6.01" y1="6" y2="6"/><line x1="6" x2="6.01" y1="18" y2="18"/></svg>`,
  },
  {
    title: "Ruby Developers",
    description: "Extend with familiar tools — gems, RSpec, Bundler. Build custom extensions with scaffolding, auto-discovery, and a rich plugin API.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m18 16 4-4-4-4"/><path d="m6 8-4 4 4 4"/><path d="m14.5 4-5 16"/></svg>`,
  },
  {
    title: "Open Source Contributors",
    description: "369 repos. Apache 2.0 core. MIT extensions. No paid tiers, no feature gates. Every contribution shapes the future of cognitive AI.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>`,
  },
];
---

<section id="community" class="py-20 md:py-32">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <SectionHeading
      label="Community"
      title="Community"
      subtitle="Built for researchers, engineers, Ruby developers, and open source contributors."
    />

    <div class="grid md:grid-cols-2 gap-5" data-reveal-stagger>
      {audiences.map((item) => (
        <GlowCard class="group">
          <div class="text-violet-primary mb-4 group-hover:text-lavender transition-colors duration-300" set:html={item.icon} />
          <h3 class="text-lg font-heading font-semibold text-surface-100 mb-2">{item.title}</h3>
          <p class="text-sm text-surface-400 leading-relaxed">{item.description}</p>
        </GlowCard>
      ))}
    </div>
  </div>
</section>
