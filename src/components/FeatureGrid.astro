---
import SectionHeading from "./ui/SectionHeading.astro";
import GlowCard from "./ui/GlowCard.astro";

const features = [
  {
    title: "Tiered Model Routing",
    description: "Every model is classified into a tier: local, direct, fleet, cloud, frontier. Each request starts at the most cost-effective tier that can handle it and escalates automatically on failure or capability mismatch.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12h5"/><path d="M17 12h5"/><path d="m7 7 5 5-5 5"/><path d="m12 7 5 5-5 5"/></svg>`,
  },
  {
    title: "Mid-Stream Failover",
    description: "Per-provider circuit breakers (3 failures in a 300s window trips, 60s cooldown). A provider dying mid-stream fails over to the next candidate and the client stream continues instead of erroring.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-6.219-8.56"/><polyline points="22 2 12 12 16 16"/></svg>`,
  },
  {
    title: "Context Curation",
    description: "Six deterministic strategies shrink conversation history after each turn, asynchronously. Production result: single-turn traffic unchanged, 50+ turn agent sessions reduced 97.7% versus naive resend.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>`,
  },
  {
    title: "Any Client, Any Model",
    description: "Client dialects are translated at the boundary, so existing tools keep working while requests route anywhere: a frontier API call can land on a local GPU without the client knowing or caring.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76Z"/></svg>`,
  },
  {
    title: "Async Job Engine",
    description: "Task chains with conditions and transformations, eight actor types, distributed cron scheduling, and a disk spool that buffers through broker outages. Scale by starting more processes.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="8" x="2" y="2" rx="2" ry="2"/><rect width="20" height="8" x="2" y="14" rx="2" ry="2"/><line x1="6" x2="6.01" y1="6" y2="6"/><line x1="6" x2="6.01" y1="18" y2="18"/></svg>`,
  },
  {
    title: "Zero-Infra Lite Mode",
    description: "LEGION_MODE=lite swaps RabbitMQ for in-process pub/sub and Redis for an in-memory cache. Every feature works with nothing external installed. Evaluating the framework takes about five minutes.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5"/><line x1="12" x2="20" y1="19" y2="19"/></svg>`,
  },
  {
    title: "MCP Server",
    description: "Runs over stdio or streamable HTTP. Tools are discovered at runtime from installed extensions, so the tool list reflects what your deployment can actually do, not a hardcoded catalog.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
  },
  {
    title: "Audit Ledger & RBAC",
    description: "lex-llm-ledger records every request: tokens, routing decisions, curation deltas, tool calls. It exists for finance and compliance — and it is how every number on this page was measured. Install it and get the same receipts for your own traffic.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22v-5"/><path d="M9 8V2"/><path d="M15 8V2"/><path d="M18 8v5a6 6 0 0 1-6 6 6 6 0 0 1-6-6V8Z"/></svg>`,
  },
];
---

<section id="features" class="py-14 md:py-20">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <SectionHeading
      label="Features"
      title="Features"
      subtitle="What ships today, described the way the code implements it."
    />

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-5" data-reveal-stagger>
      {features.map((feature) => (
        <GlowCard class="group">
          <div class="text-violet-primary mb-4 group-hover:text-lavender transition-colors duration-300" set:html={feature.icon} />
          <h3 class="text-base font-heading font-semibold text-surface-100 mb-2">{feature.title}</h3>
          <p class="text-sm text-surface-400 leading-relaxed">{feature.description}</p>
        </GlowCard>
      ))}
    </div>
  </div>
</section>
