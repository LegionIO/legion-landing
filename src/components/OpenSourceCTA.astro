---
import Button from "./ui/Button.astro";

const glassCardStyle = "backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);";
---

<section id="open-source" class="py-20 md:py-32 relative overflow-hidden">
  <!-- Background gradient -->
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-violet-primary/5 to-transparent"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] bg-violet-primary/8 rounded-full blur-[100px]"></div>

  <div class="relative max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center" data-reveal>
    <span class="inline-block text-xs font-mono font-semibold tracking-widest uppercase text-violet-primary mb-4">
      Open Source
    </span>
    <h2 class="text-3xl md:text-4xl lg:text-5xl font-heading font-bold text-surface-100 mb-4">
      Open Source
    </h2>
    <p class="text-lg text-surface-400 mb-10 leading-relaxed">
      Apache 2.0 core. MIT extensions.
      <br class="hidden sm:block" />
      The full platform, yours to use, extend, and contribute to.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-12">
      <Button href="https://github.com/LegionIO" variant="primary">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
        Star on GitHub
      </Button>
      <Button href="https://legionio.dev" variant="secondary">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H19a1 1 0 0 1 1 1v18a1 1 0 0 1-1 1H6.5a1 1 0 0 1 0-5H20"/>
        </svg>
        Read the Docs
      </Button>
      <Button href="https://github.com/LegionIO/LegionIO/blob/main/CONTRIBUTING.md" variant="secondary">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M16 22s-4-2-7-5c-2.5-2.5-4-5.5-4-8.5A4.5 4.5 0 0 1 9.5 4c1.7 0 3.1.8 4.5 2.4C15.4 4.8 16.8 4 18.5 4A4.5 4.5 0 0 1 23 8.5c0 3-1.5 6-4 8.5-3 3-7 5-7 5z"/>
        </svg>
        Contribute
      </Button>
    </div>

    <!-- Install reminder -->
    <div class="inline-flex flex-col items-start gap-1 px-5 py-3 rounded-xl glass-card" style={glassCardStyle}>
      <div class="flex items-center gap-3">
        <span class="text-violet-primary font-mono text-sm">$</span>
        <code class="font-mono text-sm text-surface-200">brew tap LegionIO/tap</code>
      </div>
      <div class="flex items-center gap-3">
        <span class="text-violet-primary font-mono text-sm">$</span>
        <code class="font-mono text-sm text-surface-200">brew install legionio</code>
      </div>
      <div class="flex items-center gap-3">
        <span class="text-violet-primary font-mono text-sm">$</span>
        <code class="font-mono text-sm text-surface-200">legionio start</code>
      </div>
    </div>
  </div>
</section>
