---
import SectionHeading from "./ui/SectionHeading.astro";
import {
  siGithub,
  siDocker,
  siKubernetes,
  siVault,
  siPostgresql,
  siRedis,
  siTerraform,
  siGrafana,
  siDiscord,
  siTelegram,
  siJenkins,
  siGitlab,
  siJira,
  siPagerduty,
  siHomeassistant,
  siMqtt,
  siPrometheus,
} from "simple-icons";

const siIcon = (icon: { path: string }) =>
  `<svg viewBox="0 0 24 24" fill="currentColor"><path d="${icon.path}"/></svg>`;

const cognitiveDomains = [
  "Executive", "Attention", "Memory", "Affect", "Inference", "Social",
  "Self", "Learning", "Language", "Imagination", "Homeostasis", "Defense", "Integration",
];

const integrations = [
