<section id="extensions" class="py-20 md:py-32">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <SectionHeading
      label="Ecosystem"
      title="An Ecosystem, Not a Monolith"
      subtitle="73 extension gems and counting. Install only what you need."
    />

    <!-- Cognitive Domains -->
    <div class="mb-16" data-reveal>
      <h3 class="text-center text-lg font-heading font-semibold text-surface-200 mb-2">
        18 Cognitive Domains
      </h3>
      <p class="text-center text-sm text-surface-500 mb-8">
        242 brain-modeled extensions organized by cognitive function
      </p>
      <div class="flex flex-wrap justify-center gap-2 max-w-3xl mx-auto">
        {cognitiveDomains.map((domain) => (
          <span class="px-3 py-1.5 rounded-full text-sm font-medium bg-violet-primary/8 text-surface-300 border border-violet-primary/12 hover:border-violet-primary/30 hover:text-lavender transition-colors duration-200">
            {domain}
          </span>
        ))}
      </div>
    </div>

    <!-- Service Integrations -->
    <div data-reveal>
      <h3 class="text-center text-lg font-heading font-semibold text-surface-200 mb-2">
        80+ Service Integrations
      </h3>
      <p class="text-center text-sm text-surface-500 mb-8">
        Connect to your entire infrastructure
      </p>
      <div class="grid grid-cols-4 sm:grid-cols-5 md:grid-cols-7 lg:grid-cols-8 gap-4 max-w-4xl mx-auto">
        {integrations.map((item) => (
          <div class="group flex flex-col items-center gap-2 p-3 rounded-xl hover:bg-white/[0.03] transition-colors duration-200">
            <div class="w-8 h-8 text-surface-500 group-hover:text-lavender transition-colors duration-200" set:html={item.icon} />
            <span class="text-xs text-surface-500 group-hover:text-surface-300 transition-colors duration-200 text-center">{item.name}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
