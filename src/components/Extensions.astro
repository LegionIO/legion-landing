  { name: "Kubernetes", icon: siIcon(siKubernetes) },
  { name: "Vault", icon: siIcon(siVault) },
  { name: "PostgreSQL", icon: siIcon(siPostgresql) },
  { name: "Redis", icon: siIcon(siRedis) },
  { name: "Terraform", icon: siIcon(siTerraform) },
  { name: "Grafana", icon: siIcon(siGrafana) },
  { name: "Discord", icon: siIcon(siDiscord) },
  { name: "Telegram", icon: siIcon(siTelegram) },
  { name: "Jenkins", icon: siIcon(siJenkins) },
  { name: "GitLab", icon: siIcon(siGitlab) },
  { name: "Jira", icon: siIcon(siJira) },
  { name: "PagerDuty", icon: siIcon(siPagerduty) },
  { name: "Home Assistant", icon: siIcon(siHomeassistant) },
  { name: "MQTT", icon: siIcon(siMqtt) },
  { name: "Prometheus", icon: siIcon(siPrometheus) },
];
---

<section id="extensions" class="py-20 md:py-32">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <SectionHeading
      label="Ecosystem"
      title="Ecosystem"
      subtitle="73 extension gems and counting. Install only what you need."
    />

    <!-- Cognitive Domains -->
    <div class="mb-16" data-reveal>
      <h3 class="text-center text-lg font-heading font-semibold text-surface-200 mb-2">
        13 Cognitive Domains
      </h3>
      <p class="text-center text-sm text-surface-500 mb-8">
        234 cognitive modules organized by cognitive function
      </p>
      <div class="flex flex-wrap justify-center gap-2 max-w-3xl mx-auto">
        {cognitiveDomains.map((domain) => (
          <span class="px-3 py-1.5 rounded-full text-sm font-medium text-surface-300 glass-card glow-border hover:border-violet-primary/25 hover:bg-white/[0.06] hover:text-lavender transition-all duration-300" style="backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);">
            {domain}
          </span>
        ))}
      </div>
    </div>

    <!-- Service Integrations -->
    <div data-reveal>
      <h3 class="text-center text-lg font-heading font-semibold text-surface-200 mb-2">
        50+ Service Integrations
      </h3>
      <p class="text-center text-sm text-surface-500 mb-8">
        Connect to your entire infrastructure
      </p>
      <div class="grid grid-cols-4 sm:grid-cols-5 md:grid-cols-7 lg:grid-cols-8 gap-4 max-w-4xl mx-auto">
        {integrations.map((item) => (
          <div class="group flex flex-col items-center gap-2 p-3 rounded-xl glass-card glow-border hover:border-violet-primary/25 hover:bg-white/[0.06] transition-all duration-300" style="backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);">
            <div class="w-8 h-8 text-surface-500 group-hover:text-lavender transition-colors duration-200" set:html={item.icon} />
            <span class="text-xs text-surface-500 group-hover:text-surface-300 transition-colors duration-200 text-center whitespace-nowrap">{item.name}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
