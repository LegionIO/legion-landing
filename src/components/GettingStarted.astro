---
import SectionHeading from "./ui/SectionHeading.astro";
import CodeBlock from "./ui/CodeBlock.astro";
---

<section id="get-started" class="py-20 md:py-32">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <SectionHeading
      label="Get Started"
      title="Get Started"
      subtitle="Zero infrastructure required to get started. Add RabbitMQ, Redis, and PostgreSQL when you're ready to scale."
    />

    <div class="space-y-6" data-reveal-stagger>
      <!-- Step 1 -->
      <div>
        <div class="flex items-center gap-3 mb-3">
          <span class="flex items-center justify-center w-7 h-7 rounded-full bg-violet-primary/15 text-violet-primary text-xs font-mono font-bold">1</span>
          <h3 class="text-base font-heading font-semibold text-surface-200">Install</h3>
        </div>
        <CodeBlock
          title="terminal"
          code={`<span class="text-violet-primary">$</span> <span class="text-surface-200">gem install legionio</span>`}
        />
      </div>

      <!-- Step 2 -->
      <div>
        <div class="flex items-center gap-3 mb-3">
          <span class="flex items-center justify-center w-7 h-7 rounded-full bg-violet-primary/15 text-violet-primary text-xs font-mono font-bold">2</span>
          <h3 class="text-base font-heading font-semibold text-surface-200">Configure</h3>
        </div>
        <CodeBlock
          title="terminal"
          code={`<span class="text-violet-primary">$</span> <span class="text-surface-200">legionio config scaffold</span>   <span class="text-surface-600"># auto-detects your environment</span>\n<span class="text-violet-primary">$</span> <span class="text-surface-200">legionio check</span>             <span class="text-surface-600"># verify connections</span>`}
        />
      </div>

      <!-- Step 3 -->
      <div>
        <div class="flex items-center gap-3 mb-3">
          <span class="flex items-center justify-center w-7 h-7 rounded-full bg-violet-primary/15 text-violet-primary text-xs font-mono font-bold">3</span>
          <h3 class="text-base font-heading font-semibold text-surface-200">Launch</h3>
        </div>
        <CodeBlock
          title="terminal"
          code={`<span class="text-violet-primary">$</span> <span class="text-surface-200">legion</span>                     <span class="text-surface-600"># interactive TTY shell</span>\n<span class="text-violet-primary">$</span> <span class="text-surface-200">legion chat</span>                <span class="text-surface-600"># AI-powered REPL</span>\n<span class="text-violet-primary">$</span> <span class="text-surface-200">legionio start</span>             <span class="text-surface-600"># start the daemon</span>`}
        />
      </div>
    </div>

    <!-- Zero infra note -->
    <div class="mt-8 text-center" data-reveal>
      <p class="inline-flex items-center gap-2 text-sm text-surface-400 px-4 py-2 rounded-full bg-surface-850 border border-white/5">
        <svg class="w-4 h-4 text-violet-primary" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/>
          <path d="M12 16v-4"/>
          <path d="M12 8h.01"/>
        </svg>
        Works in zero-infrastructure mode — no RabbitMQ or Redis required to get started.
      </p>
    </div>
  </div>
</section>
