---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import HeroNeuralField from "../components/HeroNeuralField.astro";
import Comparison from "../components/Comparison.astro";
import Architecture from "../components/Architecture.astro";
import FeatureGrid from "../components/FeatureGrid.astro";
import Extensions from "../components/Extensions.astro";
import GettingStarted from "../components/GettingStarted.astro";
import Audience from "../components/Audience.astro";
import OpenSourceCTA from "../components/OpenSourceCTA.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout>
  <Nav />
  <main class="landing-main relative overflow-hidden" data-neural-root>
    <HeroNeuralField />
    <Hero />
    <Comparison />
    <Architecture />
    <FeatureGrid />
    <Extensions />
    <GettingStarted />
    <Audience />
    <OpenSourceCTA />
  </main>
  <Footer />
</BaseLayout>
